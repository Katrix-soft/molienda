{
  "name": "katrix-biometrics",
  "version": "1.0.0",
  "description": "Framework-agnostic WebAuthn/FIDO2 library",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Katrix-soft/katrix-biometrics.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webauthn",
    "fido2",
    "biometrics",
    "authentication",
    "passwordless"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
